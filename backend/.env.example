# =========================
# 🌐 APP
# =========================
APP_NAME=central-transfers
ENV=production

# =========================
# 🔐 SEGURANÇA
# =========================
# Gere uma chave nova: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# 🗄️ DATABASE (POSTGRESQL - AIVEN)
# =========================
# Formato: postgresql+psycopg2://user:password@host:port/dbname?sslmode=require
DATABASE_URL=sua_url_do_aiven_aqui

# =========================
# 💳 MERCADO PAGO
# =========================
MERCADO_PAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# =========================
# 📲 WHATSAPP (META API)
# =========================
WHATSAPP_TOKEN=seu_token_meta_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_id_do_telefone_aqui
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao_escolhido

# =========================
# 🌍 CORS
# =========================
ALLOWED_ORIGINS=*