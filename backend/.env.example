# =========================
# 🌐 APP
# =========================
APP_NAME=central-transfers
ENV=production

# =========================
# 🔐 SEGURANÇA
# =========================
SECRET_KEY=GERAR_UMA_CHAVE_FORTE_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# 🗄️ DATABASE (POSTGRESQL - AIVEN)
# =========================
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# =========================
# 💳 MERCADO PAGO
# =========================
MERCADO_PAGO_ACCESS_TOKEN=NOVO_TOKEN_AQUI
MERCADO_PAGO_WEBHOOK_SECRET=NOVO_SECRET_AQUI

# =========================
# 📲 WHATSAPP (META API)
# =========================
WHATSAPP_TOKEN=NOVO_TOKEN_AQUI
WHATSAPP_PHONE_NUMBER_ID=SEU_ID
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=TOKEN_VERIFICACAO

# =========================
# 🌍 CORS
# =========================
ALLOWED_ORIGINS=*